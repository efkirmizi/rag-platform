# Varsayılanlar docker-compose ile birebir uyumludur; .env olmadan da çalışır.
DATABASE_URL=postgresql://rag:ragpass@localhost:5432/rag
FGA_API_URL=http://localhost:8080
# Boş bırakılırsa infra/openfga/store.state.json dosyasından okunur (seed script yazar)
FGA_STORE_ID=
FGA_MODEL_ID=

# fake  : deterministik sahte embedding — SADECE ACL/latency testi için (G-1)
# local : sentence-transformers, GPU otomatik (G-2; pip install -e ".[local]")
# openai: vLLM/OpenAI-uyumlu endpoint — üretim hedefi
EMBEDDINGS_PROVIDER=fake
EMBEDDINGS_DIM=1024
EMBEDDINGS_ENDPOINT=
EMBEDDINGS_MODEL=
EMBEDDINGS_API_KEY=
# local sağlayıcı donanımı: auto (cuda varsa cuda+float16, yoksa cpu) | cuda | cpu
EMBEDDINGS_DEVICE=auto
EMBEDDINGS_DTYPE=auto

# noop: RRF sırasını korur (varsayılan). local: bge-reranker-v2-m3 cross-encoder (G-2)
RERANKER_PROVIDER=noop
RERANKER_MODEL=

ACL_CACHE_TTL_SECONDS=60
